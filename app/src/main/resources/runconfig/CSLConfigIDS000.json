"udp_server_conf": {
	"on":true,
	"verbose":true,	
	"trace_all_messages":false,
	"port":8001,
	"max_input_queues":10,
	"max_size_of_input_queues":100	
},



"file_server_conf": {
	"on":false,
	"verbose":true,
	"port":8010,
	"root_file_dir":"./idslogs"
},

"config_file_manager_conf": {
	"on":true,
	"verbose":true,
	"show_modified_files":true,
	"root_conf_dir":"./idsconf",
	"conf_files":["demo.json","NewLearnedRules.json", "RulesForDetection.txt","RulesForLearning.txt","LearnedRules.json","SystemConfiguration.json"],
	"max_number_of_version":10
},


"external_commands":{
	"commands":[
		{ "name":"start_modbus",
		  "dir":"",
		  "mode":"script",
		  "sudo":true,
		  "script":"start_modbuspal.sh",
		  "kill_filter":"modbuspal",
		  "kill_script":"stop_modbuspal.sh",
		  "kill_if_running":true,
		  "show_output":true
		},
		{ "name":"start_logview",
		  "dir":"",
		  "mode":"jar",
		  "jar":"Logview.jar",
		  "kill_filter":"main.ProcessUtil",
		  "kill_if_running":true,
		  "show_output":true
		},
		{ "name":"start_all",
		  "mode":"macro",
		  "commands":["start_modbus","start_logview"]
		}			
	]

},


"module_exec":{
	"sampling_time":1000,
	"modules_package_name":"main.modules",
	"number_of_exec_loops": 2,
	"autostart":true
},

"modules":[
	{
		"name":"module_ids",
		"type":"ModuleIDS",
		"config":{
		  "autostart": true,
		  "exec_loop_number": 1,
		  "input_priority":90,
		  "step_priority":99,
		  "output_priority":98
		}
	} 	
],

"ids_conf":{
	"on":true,
	"mode":0,
	"help_mode":"0:idle, 1:record only, 2: detect online 3: learning 4: detect offline",
	
	"working_dir":"/Users/flausj/Documents/dev/data/poc/0-comportement_normal",
	
	"subdir_learn":"",
	"help_subdir_learn":"The data for learning are in a subdir of working_dir",
	"subdir_offline_detect":"test",
	"help_subdir_detect":"The data for off line detect are in a subdir of working_dir",
	
	"idsconf_dir":"idsconf",
	"idsconf_dir_relative_to_data_dir":false,
	
	"rules_for_detection":"RulesForDetection.txt",
	"rules_for_learning":"RulesForLearning.txt",
	"learned_model":"LearnedRules.json",
	"new_learned_model":"NewLearnedRules.json",
	"system_configuration":"SystemConfiguration.json",
	
	"idstrace_flags":["alert:0","dpi:false","syslearn:0","setrisk:0"],
	"idstrace_dir":"./idslogs/trace",
	"idstrace_on":true,
	
	"log_to_file":true,
    "variables_prefix_filename":"VARIABLES",
    "packets_prefix_filename":"PACKETS",
    "network_prefix_filename":"NETWORK",
	
    "max_size_of_log_files": 100000000,
    "idslogs_dir": "idslogs/logs",
    
    "send_to_console":false,
    "send_to_browser":true,
    
    "kill_previous_instance":true
},

"alert_viewer":{
		"ip":"localhost",
		"port":4445,
		"name":"My Alerts",
		"logToFile":true,
		"data_dir":"./idslogs/alerts",
		"prefix_filename":"AL",
		"max_size_of_log_files":10000,
		"alert_to_web":true,
		"alert_json_tag":"alert",
		"alert_to_udp":false
	
	}
	



	
